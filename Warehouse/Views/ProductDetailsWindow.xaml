<Window x:Class="Warehouse.Views.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Warehouse.UserControls"
        Title="Edytor Produktu" Height="800" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Zdjęcie Etykiety" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <Image Source="{Binding ProductLabelImagePath}" Height="150" Margin="0,5" Stretch="Uniform"/>
                <Button Content="Zmień/Dodaj Etykietę" Command="{Binding SelectLabelImageCommand}" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Zdjęcie Produktu" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <Image Source="{Binding ProductImagePath}" Height="150" Margin="0,5" Stretch="Uniform"/>
                <Button Content="Zmień/Dodaj Zdjęcie" Command="{Binding SelectImageCommand}" Padding="5"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Text="Nazwa produktu:" FontWeight="SemiBold" />
        <TextBox Grid.Row="2" Text="{Binding ProductName, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,15">
                <TextBlock Text="Ilość początkowa:" FontWeight="SemiBold" />
                <TextBox Text="{Binding ProductQuantity, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNewProduct}" Margin="0,5,0,0" Padding="5" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,15">
                <TextBlock Text="Cena:" FontWeight="SemiBold" />
                <TextBox Text="{Binding ProductPriceAmount, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" Padding="5" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="4" Text="Grupa:" FontWeight="SemiBold" />
        <uc:GroupSelectionControl Grid.Row="5" DataContext="{Binding CategorySelector}" Margin="0,5,0,15" />

        <TextBlock Grid.Row="6" Text="Kategoria:" FontWeight="SemiBold" />
        <uc:CategorySelectionControl Grid.Row="7" DataContext="{Binding CategorySelector}" Margin="0,5,0,15" />

        <Grid Grid.Row="9" Margin="0,20,0,0" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Zapisz" Command="{Binding SaveCommand}" Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="10" Margin="0,0,10,0" />
            <Button Grid.Column="1" Content="Usuń" Command="{Binding DeleteCommand}" Background="#F44336" Foreground="White" FontWeight="Bold" Padding="20,10" Visibility="{Binding IsNewProduct, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Window>