<Window x:Class="Warehouse.Views.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:types="clr-namespace:Warehouse.Models.Types"
        xmlns:uc="clr-namespace:Warehouse.UserControls"
        Title="Edytor Produktu"
        Width="650"
        Height="900"
        MinWidth="550"
        MinHeight="700"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ObjectDataProvider x:Key="dataFromEnum"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="types:Currency"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Kod kreskowy:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ProductBarcode, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Nazwa produktu:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ProductName, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Cena:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ProductPriceAmount, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Waluta:"
                               FontWeight="SemiBold"/>

                    <ComboBox ItemsSource="{Binding Source={StaticResource dataFromEnum}}"
                              SelectedItem="{Binding SelectedCurrency}"
                              Margin="0,5,0,0"
                              Padding="5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Aktualny stan:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ProductQuantity, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Grupa:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <uc:GroupSelectionControl DataContext="{Binding CategorySelector}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Kategoria:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <uc:CategorySelectionControl DataContext="{Binding CategorySelector}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="4" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Opis:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ProductDescription, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"
                             Height="180"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Rozpoznany tekst etykiety:"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ExtractedText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,0"
                             Padding="5"
                             Height="180"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="#F5F5F5"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Zdjęcie Etykiety"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <Border BorderBrush="#DDD"
                            BorderThickness="1"
                            Padding="5"
                            Margin="0,5">
                        <Image Source="{Binding ProductLabelImageSource}"
                               Height="180"
                               Stretch="Uniform"/>
                    </Border>

                    <Button Content="Wybierz Etykietę"
                            Command="{Binding SelectLabelImageCommand}"
                            Padding="5"/>

                    <Button Content="Skanuj etykietę"
                            Command="{Binding ExtractTextFromLabelCommand}"
                            Padding="5"
                            Margin="0,5,0,0"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"/>

                    <Button Content="Tłumacz na Opis"
                            Command="{Binding TranslateLabelCommand}"
                            Padding="5"
                            Margin="0,5,0,0"
                            Background="#FF9800"
                            Foreground="White"
                            FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Zdjęcie Produktu"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <Border BorderBrush="#DDD"
                            BorderThickness="1"
                            Padding="5"
                            Margin="0,5">
                        <Image Source="{Binding ProductImageSource}"
                               Height="180"
                               Stretch="Uniform"/>
                    </Border>

                    <Button Content="Wybierz Zdjęcie"
                            Command="{Binding SelectImageCommand}"
                            Padding="5"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="6" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Zapisz do Bazy"
                        Command="{Binding SaveCommand}"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="10"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        Content="Usuń"
                        Command="{Binding DeleteCommand}"
                        Background="#F44336"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="20,10"
                        Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</Window>