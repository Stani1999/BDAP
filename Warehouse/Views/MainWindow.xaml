<Window x:Class="Warehouse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Warehouse.UserControls"
        Title="Warehouse Management System - Big Data" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <uc:SearchBarControl Grid.Column="0" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                <Button Content="Dodaj Produkt" Padding="15,10" FontWeight="Bold" Click="AddProduct_Click" />
                <Button Content="Raporty" Padding="15,10" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>

        <uc:ProductListControl Grid.Row="1" />

        <uc:PaginationControl Grid.Row="2" />

    </Grid>
</Window>