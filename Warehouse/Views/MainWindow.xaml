<Window x:Class="Warehouse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Warehouse.UserControls"
        Title="Warehouse Management System - Big Data" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <uc:SearchBarControl />
                <StackPanel Orientation="Horizontal" Margin="10,5,10,0">
                    <TextBlock Text="Filtruj - Grupa: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" />
                    <uc:GroupSelectionControl DataContext="{Binding CategorySelector}" Width="200" Margin="0,0,20,0" />

                    <TextBlock Text="Kategoria: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" />
                    <uc:CategorySelectionControl DataContext="{Binding CategorySelector}" Width="200" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Top">
                <Button Content="Dodaj Produkt" Padding="15,10" FontWeight="Bold" Click="AddProduct_Click" />
                <Button Content="Raporty" Padding="15,10" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>

        <uc:ProductListControl Grid.Row="1" />
        <uc:PaginationControl Grid.Row="2" />
    </Grid>
</Window>