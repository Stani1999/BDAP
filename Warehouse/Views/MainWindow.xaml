<Window x:Class="Warehouse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Warehouse.UserControls"
        xmlns:views="clr-namespace:Warehouse.Views"
        Title="Warehouse Management System - Big Data" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
        <Grid MinHeight="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
            <Grid Visibility="{Binding IsListVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Wyszukiwarka Produktów" FontSize="20" FontWeight="Bold" Margin="10,5,0,0" Foreground="#333" />
                        <uc:SearchBarControl />
                        <StackPanel Orientation="Horizontal" Margin="10,0,10,0">
                            <TextBlock Text="Filtruj - Grupa: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" />
                            <uc:GroupSelectionControl DataContext="{Binding CategorySelector}" Width="250" Margin="0,0,20,0" />

                            <TextBlock Text="Kategoria: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" />
                            <uc:CategorySelectionControl DataContext="{Binding CategorySelector}" Width="250" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,10,0" VerticalAlignment="Center">
                        <Button Content="Dodaj Produkt" Command="{Binding ShowAddDetailsCommand}" Padding="25,12" FontWeight="Bold" Background="#4CAF50" Foreground="White" />
                        <Button Content="Raporty" Padding="25,12" Margin="15,0,0,0" FontWeight="Bold" Background="#2196F3" Foreground="White" Click="OpenReports_Click" />
                    </StackPanel>
                </Grid>

                <uc:ProductListControl Grid.Row="1" />
                <uc:PaginationControl Grid.Row="2" />
            </Grid>

            <Grid Visibility="{Binding IsDetailsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <views:ProductDetailsView DataContext="{Binding DetailsViewModel}" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>