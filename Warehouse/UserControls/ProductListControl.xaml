<UserControl x:Class="Warehouse.UserControls.ProductListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <DataGrid Grid.Column="0" ItemsSource="{Binding Products}" 
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  CanUserSortColumns="True"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod" Binding="{Binding Barcode}" Width="150" />
                <DataGridTextColumn Header="Nazwa Produktu" Binding="{Binding Name}" Width="200" />
                <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="70" />
                <DataGridTextColumn Header="Cena" Binding="{Binding Price.Amount}" Width="70" />
                <DataGridTextColumn Header="Waluta" Binding="{Binding Price.Currency}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <TextBlock Text="Pogląd Produktu" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <Border BorderBrush="#DDDDDD" BorderThickness="1" Background="White" Height="250" Margin="0,0,0,20" CornerRadius="4">
                <Image Source="{Binding SelectedProduct.ImageData, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="Uniform" Margin="10"/>
            </Border>

            <TextBlock Text="Etykieta" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <Border BorderBrush="#DDDDDD" BorderThickness="1" Background="White" Height="250" CornerRadius="4">
                <Image Source="{Binding SelectedProduct.LabelImageData, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="Uniform" Margin="10"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>