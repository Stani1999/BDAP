<UserControl x:Class="Warehouse.UserControls.ProductListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <DataGrid ItemsSource="{Binding Products}" 
              SelectedItem="{Binding SelectedProduct}"
              AutoGenerateColumns="False" 
              IsReadOnly="True"
              SelectionMode="Single"
              VirtualizingStackPanel.IsVirtualizing="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              EnableRowVirtualization="True"
              MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod Kreskowy (ID)" Binding="{Binding Id}" Width="200" />
                <DataGridTextColumn Header="Nazwa Produktu" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Ilość (Cache)" Binding="{Binding Quantity}" Width="100" />
                <DataGridTextColumn Header="Cena" Binding="{Binding Price.Amount}" Width="80" />
                <DataGridTextColumn Header="Waluta" Binding="{Binding Price.Currency}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>