<UserControl x:Class="Warehouse.UserControls.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
        <Button Content="&lt; Poprzednia" 
                Command="{Binding PreviousPageCommand}" 
                Padding="15,5" 
                Margin="0,0,15,0" />

        <TextBlock Text="Strona: " VerticalAlignment="Center" FontSize="14" />
        <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" />

        <Button Content="Następna &gt;" 
                Command="{Binding NextPageCommand}" 
                Padding="15,5" />
    </StackPanel>
</UserControl>